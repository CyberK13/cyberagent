# ═══════════════════════════════════════════════════════════════════
# cyberagent .env.example
# ═══════════════════════════════════════════════════════════════════
# cyberagent is a "bring your own key" SDK. You can pass keys directly in
# code (AnalystChain(llm="gemini", api_key="...")) — this file is just a
# convenient default for local dev / the CLI. Set only what you use.
# Copy to .env and fill in. NEVER commit a real .env.
# ═══════════════════════════════════════════════════════════════════

# ───── LLM providers — MODEL SELECTION ─────
# Pick a model in the CLI (`cyberagent` interactive menu) or with `--llm`; the
# matching API key below is auto-selected. Fill the key + (optional) model for
# each provider you want available. Gemini is the default and powers grounding.

# Gemini — default LLM + real-time grounding (Google Search). key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-pro

# OpenAI. key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (Claude). key: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# DeepSeek. key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# xAI Grok (optional). key: https://console.x.ai/
XAI_API_KEY=
XAI_MODEL=grok-4

# ───── Search / grounding ─────
# Default = Gemini grounding (uses GOOGLE_API_KEY above). Optional alternative:
BRAVE_SEARCH_API_KEY=        # optional alt web search

# ───── Market data: stocks ─────
# US / HK via yfinance — NO key required.
TUSHARE_TOKEN=               # A-share (CN) fundamentals
FINNHUB_API_KEY=             # US fundamentals (optional)
ALPHA_VANTAGE_KEY=           # US backup data (optional)
POLYGON_API_KEY=             # US market data (optional)

# ───── Market data: crypto ─────
# CoinGecko + DefiLlama — NO key required (free tier).
ETHERSCAN_API_KEY=           # EVM contract analysis (optional; for 0x... inputs)

# ───── Macro / economics (dept: economics) ─────
FRED_API_KEY=                # US macro / economic data (optional)

# ───── News (optional; catalysts / consensus) ─────
NEWSAPI_KEY=                 # optional breaking news
GUARDIAN_API_KEY=            # optional news
