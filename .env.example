# ═══════════════════════════════════════════════════════════════════
# cyberagent .env.example
# ═══════════════════════════════════════════════════════════════════
# cyberagent is a pure "bring your own LLM key" SDK — no server, no
# database. You can also pass keys directly in code
# (AnalystChain(llm='gemini', api_key='...')); this file is just a
# convenient default for local dev and the CLI.
#
# Everything below is OPTIONAL — set only the providers/markets you use.
# ═══════════════════════════════════════════════════════════════════

# ───── LLM providers (pick one or more — bring your own key) ─────

# Gemini — default provider for the 5-department chain
# key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-pro

# OpenAI
# key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

# Anthropic (Claude)
# key: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# DeepSeek
# key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ───── Market data adapters ─────

# Tushare — A-share (CN) fundamentals & quotes
# token: https://tushare.pro/register
TUSHARE_TOKEN=

# US / HK stocks via yfinance — no key required (needs network access).
# US SEC filings via EDGAR — no key required (sends a User-Agent header).
# Crypto (token) via CoinGecko + DefiLlama — no key required (free tier).

# Etherscan — EVM contract analysis (optional; only for '0x...' inputs)
# key: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
